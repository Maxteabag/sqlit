{
  "_note": "Copy to ~/.config/sqlit/keymap.json (no subdir) — sqlit loads it automatically. List only the bindings you want to change. See docs/custom-keymaps.md for the action/state catalog.",
  "keymap": {
    "action_keys": {
      "query_normal": {
        "execute_query": "ctrl+enter"
      },
      "autocomplete": {
        "autocomplete_next": "ctrl+n",
        "autocomplete_prev": "ctrl+p"
      },
      "tree": {
        "tree_cursor_down": ["j", "down"],
        "tree_cursor_up": ["k", "up"]
      }
    },
    "leader_commands": {
      "leader": {
        "show_help": "question_mark"
      }
    }
  }
}
